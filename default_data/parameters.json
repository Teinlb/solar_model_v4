{
  "car": {
    "mass": {
      "default": 1000,
      "constraints": {
        "min": 50,
        "max": 5000,
        "type": "float",
        "read_only": 0
      },
      "ui": {
        "label": "Mass (kg)",
        "widget": "input",
        "info": "Total vehicle mass. Used in drag, rolling resistance, slope, and acceleration"
      }
    },
    "frontal_area": {
      "default": 2,
      "constraints": {
        "min": 0.1,
        "max": 10,
        "type": "float"
      },
      "ui": {
        "label": "Frontal area (m\u00b2)",
        "widget": "frontal",
        "info": "Vehicle cross-sectional area for aerodynamic drag (width \u00d7 height \u00d7 shape factor)"
      }
    },
    "drag_coeff": {
      "default": 0.2,
      "constraints": {
        "min": 0.01,
        "max": 1,
        "type": "float"
      },
      "ui": {
        "label": "Drag coefficient (Cd)",
        "widget": "dropdown",
        "options": [
          {
            "value": 0.14,
            "label": "Extreem gestroomlijnd (0.14)"
          },
          {
            "value": 0.2,
            "label": "Zeer gestroomlijnd (0.20)"
          },
          {
            "value": 0.28,
            "label": "Gemiddelde personenauto (0.28)"
          },
          {
            "value": 0.38,
            "label": "SUV (0.38)"
          }
        ],
        "info": "Aerodynamic drag coefficient"
      }
    },
    "rolling_res": {
      "default": 0.015,
      "constraints": {
        "min": 0.001,
        "max": 0.1,
        "type": "float"
      },
      "ui": {
        "label": "Rolling resistance (Cr)",
        "widget": "dropdown",
        "options": [
          {
            "value": 0.004,
            "label": "0.004"
          },
          {
            "value": 0.008,
            "label": "0.008"
          },
          {
            "value": 0.01,
            "label": "0.01"
          },
          {
            "value": 0.015,
            "label": "0.015 - Standaard banden op strak geasfalteerd wegdek"
          },
          {
            "value": 0.02,
            "label": "0.02 - Wegdek van teer, asfalt, of nieuw gravel wegdek"
          },
          {
            "value": 0.03,
            "label": "0.03 - Oud wegdek met kiezels"
          },
          {
            "value": 0.04,
            "label": "0.04"
          },
          {
            "value": 0.06,
            "label": "0.06 - Onverhard wegdek"
          }
        ],
        "info": "Rolling resistance coefficient"
      }
    },
    "battery_capacity": {
      "default": 72000000,
      "constraints": {
        "min": 0,
        "type": "float"
      },
      "ui": {
        "label": "Battery capacity (J)",
        "widget": "input",
        "note": "20 kWh default",
        "info": "Total energy storage in joules"
      }
    },
    "battery_efficiency": {
      "default": 0.95,
      "constraints": {
        "min": 0.01,
        "max": 1,
        "type": "float"
      },
      "ui": {
        "label": "Battery efficiency",
        "widget": "slider",
        "info": "Round-trip charging/discharging efficiency"
      }
    },
    "motor_efficiency": {
      "default": 0.9,
      "constraints": {
        "min": 0.01,
        "max": 1,
        "type": "float"
      },
      "ui": {
        "label": "Motor efficiency",
        "widget": "slider",
        "info": "Drivetrain electrical to mechanical conversion efficiency"
      }
    },
    "available_capacity": {
      "default": 100,
      "constraints": {
        "min": 0,
        "max": 100,
        "type": "float"
      },
      "ui": {
        "label": "Available capacity (%)",
        "widget": "slider",
        "info": "Usable fraction of total battery capacity"
      }
    },
    "aux_power": {
      "default": 200,
      "constraints": {
        "min": 0,
        "max": 10000,
        "type": "float"
      },
      "ui": {
        "label": "Aux power (W)",
        "widget": "input",
        "info": "Baseline consumption for lights, dashboard, telemetry"
      }
    },
    "regen_efficiency": {
      "default": 0.7,
      "constraints": {
        "min": 0,
        "max": 1,
        "type": "float"
      },
      "ui": {
        "label": "Regen efficiency",
        "widget": "slider",
        "info": "Energy recovery during braking"
      }
    },
    "panel_area": {
      "default": 5,
      "constraints": {
        "min": 0,
        "max": 50,
        "type": "float"
      },
      "ui": {
        "label": "Panel area (m\u00b2)",
        "widget": "input",
        "info": "Total solar panel surface area"
      }
    },
    "panel_efficiency": {
      "default": 0.22,
      "constraints": {
        "min": 0.01,
        "max": 1,
        "type": "float"
      },
      "ui": {
        "label": "Panel efficiency",
        "widget": "slider",
        "info": "Solar panel conversion efficiency."
      }
    },
    "panel_temp_coeff": {
      "default": -0.003,
      "constraints": {
        "min": -0.05,
        "max": 0.05,
        "type": "float"
      },
      "ui": {
        "label": "Panel temp coeff (%/\u00b0C)",
        "widget": "hidden",
        "info": "Panel efficiency change per degree Celsius"
      }
    }
  },
  "profile": {
    "type": {
      "default": "cycle",
      "constraints": {
        "type": "string"
      },
      "ui": {
        "label": "Profile type",
        "widget": "dropdown",
        "options": [
          {
            "value": "cycle",
            "label": "Cycle profile"
          },
          {
            "value": "constant",
            "label": "Constant profile"
          }
        ],
        "info": "Select the type of driving profile to use"
      }
    },
    "target_speed": {
      "default": 20,
      "constraints": {
        "min": 0,
        "max": 100,
        "type": "float"
      },
      "ui": {
        "label": "Target speed (m/s)",
        "widget": "input",
        "info": "Constant speed for constant profile"
      }
    },
    "ref": {
      "default": "drivecycles/WLTP.csv",
      "constraints": {
        "type": "string"
      },
      "ui": {
        "label": "Drive cycle reference",
        "widget": "dropdown",
        "options": [
          {
            "value": "drivecycles/WLTP.csv",
            "label": "WLTP"
          }
        ],
        "info": "Path to the drive cycle CSV file"
      }
    }
  },
  "env": {
    "air_density": {
      "default": 1.225,
      "constraints": {
        "min": 0.8,
        "max": 1.5,
        "type": "float"
      },
      "ui": {
        "label": "Air density (kg/m\u00b3)",
        "widget": "input",
        "info": "Atmospheric density. Affects drag and energy calculations"
      }
    },
    "gravity": {
      "default": 9.81,
      "constraints": {
        "read_only": true
      },
      "ui": {
        "label": "Gravity (m/s\u00b2)",
        "note": "constant"
      }
    },
    "temperature": {
      "default": 25,
      "constraints": {
        "min": -50,
        "max": 80,
        "type": "float"
      },
      "ui": {
        "label": "Temperature (\u00b0C)",
        "widget": "slider",
        "info": "Ambient temperature. Affects solar panel efficiency"
      }
    },
    "wind_speed": {
      "default": 0,
      "constraints": {
        "min": 0,
        "max": 60,
        "type": "float"
      },
      "ui": {
        "label": "Wind speed (m/s)",
        "widget": "hidden",
        "info": "Wind velocity magnitude"
      }
    },
    "wind_direction": {
      "default": 0,
      "constraints": {
        "min": 0,
        "max": 360,
        "type": "float"
      },
      "ui": {
        "label": "Wind direction (\u00b0)",
        "widget": "hidden",
        "info": "Wind direction in degrees"
      }
    },
    "solar_irradiance": {
      "default": 1000,
      "constraints": {
        "min": 0,
        "max": 1400,
        "type": "float"
      },
      "ui": {
        "label": "Solar irradiance (W/m\u00b2)",
        "widget": "slider",
        "info": "Incoming solar radiation intensity. Primary power generation input"
      }
    },
    "slope": {
      "default": 0,
      "constraints": {
        "min": -45,
        "max": 45,
        "type": "float"
      },
      "ui": {
        "label": "Slope (\u00b0)",
        "widget": "slider",
        "info": "Road inclination angle"
      }
    }
  },
  "sim": {
    "duration": {
      "default": 86400,
      "constraints": {
        "min": 3600,
        "max": 604800,
        "type": "float"
      },
      "ui": {
        "label": "Duration (s)",
        "widget": "input",
        "note": "1-7 days",
        "info": "Total simulation duration in seconds"
      }
    },
    "time_step": {
      "default": 1,
      "constraints": {
        "min": 0.01,
        "max": 10,
        "type": "float"
      },
      "ui": {
        "label": "Time step (s)",
        "widget": "slider",
        "info": "Interval for simulation calculations"
      }
    }
  }
}